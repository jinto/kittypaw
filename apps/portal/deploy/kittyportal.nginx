upstream kittyportal {
  server unix:/home/jinto/kittyportal/kittyportal.sock;
}

server {
  listen 80;
  server_name {{DOMAIN}};

  location / {
    proxy_pass http://kittyportal;
    include proxy_params;
    proxy_set_header True-Client-IP "";
    proxy_set_header X-Forwarded-For $remote_addr;
  }
}
