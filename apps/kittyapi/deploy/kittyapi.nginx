upstream kittyapi {
  server 127.0.0.1:9712;
}

server {
  listen 80;
  server_name {{DOMAIN}};

  location = /health {
    proxy_pass http://kittyapi;
    include proxy_params;
    proxy_set_header True-Client-IP "";
    proxy_set_header X-Forwarded-For $remote_addr;
  }

  location /v1/ {
    proxy_pass http://kittyapi;
    include proxy_params;
    proxy_set_header True-Client-IP "";
    proxy_set_header X-Forwarded-For $remote_addr;
  }

  location / {
    return 404;
  }
}

server {
  listen 80;
  server_name {{PORTAL_DOMAIN}};

  location / {
    proxy_pass http://kittyapi;
    include proxy_params;

    # Strip headers that proxy_params does NOT canonicalize. Without
    # these, an attacker could rotate True-Client-IP / X-Forwarded-For
    # per request to bypass the anonymous rate limit. The kittyapi side
    # only trusts X-Real-IP (which proxy_params overrides safely with
    # $remote_addr); these resets are defense-in-depth.
    proxy_set_header True-Client-IP "";
    proxy_set_header X-Forwarded-For $remote_addr;
  }
}
