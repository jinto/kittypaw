KITTYCHAT_BIND_ADDR=/home/jinto/kittychat/kittychat.sock
# Set this to portal's JWKS endpoint to accept RS256 access tokens and daemon
# device credentials. Leave blank only for static-token MVP fallback.
KITTYCHAT_JWKS_URL=https://portal.kittypaw.app/.well-known/jwks.json
# Legacy HS256 fallback. Prefer KITTYCHAT_JWKS_URL for new deployments.
# KITTYCHAT_JWT_SECRET=
# Static fallback tokens are optional when KITTYCHAT_JWKS_URL is configured.
# KITTYCHAT_API_TOKEN=CHANGE_ME_API_TOKEN
# KITTYCHAT_DEVICE_TOKEN=CHANGE_ME_DEVICE_TOKEN
# The static principal values below are required only when either static token
# fallback is configured.
# KITTYCHAT_USER_ID=user_1
# KITTYCHAT_DEVICE_ID=dev_1
# KITTYCHAT_LOCAL_ACCOUNT_ID=alice
KITTYCHAT_VERSION=prod
