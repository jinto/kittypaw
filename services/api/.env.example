# Server
PORT=9712
BASE_URL=http://localhost:9712  # production: https://api.kittypaw.app

# Database
DATABASE_URL=postgres://kittypaw:kittypaw@localhost:5432/kittypaw_api?sslmode=disable

# Auth — OAuth only (Google + GitHub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# JWT (minimum 32 characters)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# CORS — comma-separated origins (defaults to BASE_URL)
# CORS_ORIGINS=https://kittypaw.app,https://api.kittypaw.app

# AirKorea (에어코리아 공공데이터 API)
AIRKOREA_API_KEY=

# Holiday (한국천문연구원 특일정보 API)
HOLIDAY_API_KEY=

# KMA Village Forecast (기상청 단기예보 공공데이터 API)
WEATHER_API_KEY=

# Kakao relay (KakaoTalk 릴레이 서버, optional)
# KAKAO_RELAY_URL=https://kakao.kittypaw.app

# API Base URL (for /discovery endpoint)
# API_BASE_URL=https://api.kittypaw.app

# Skills Registry (default: https://github.com/kittypaw-app/skills)
# SKILLS_REGISTRY_URL=https://github.com/kittypaw-app/skills
