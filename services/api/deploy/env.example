PORT=9712
BASE_URL=https://api.kittypaw.app
DATABASE_URL=postgres://kittypaw:CHANGE_ME@localhost:5432/kittypaw_api?sslmode=disable
# Plan 21 PR-B cutover: HS256 JWT_SECRET removed; required RS256 key.
# Standard base64 (RFC 4648 §4 — `+/`, NOT URL-safe `-_`) of a PEM-encoded
# RSA private key (PKCS#1 or PKCS#8), ≥2048 bits. Generate with:
#   openssl genrsa 2048 | base64 -w0
# In prod: inject from secrets manager via systemd EnvironmentFile.
JWT_PRIVATE_KEY_PEM_B64=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
CORS_ORIGINS=https://kittypaw.app,https://api.kittypaw.app
AIRKOREA_API_KEY=
